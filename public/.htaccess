# =====================================================
# SpudKick - Optimized .htaccess for Page Speed
# =====================================================

# ------------------------------------------------------
# HTTPS & WWW Enforcement
# ------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force www (comment out if you prefer non-www)
  RewriteCond %{HTTP_HOST} !^www\.
  RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [L,R=301]
</IfModule>

# ------------------------------------------------------
# Modern Compression (Brotli + Gzip)
# ------------------------------------------------------
<IfModule mod_deflate.c>
  # Compress HTML, CSS, JavaScript, Text, XML and fonts
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
  AddOutputFilterByType DEFLATE application/x-font
  AddOutputFilterByType DEFLATE application/x-font-opentype
  AddOutputFilterByType DEFLATE application/x-font-otf
  AddOutputFilterByType DEFLATE application/x-font-truetype
  AddOutputFilterByType DEFLATE application/x-font-ttf
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE font/opentype
  AddOutputFilterByType DEFLATE font/otf
  AddOutputFilterByType DEFLATE font/ttf
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE image/x-icon
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml

  # Remove browser bugs (only needed for really old browsers)
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  Header append Vary User-Agent
</IfModule>

# Brotli compression (if available - faster than gzip)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/x-javascript application/xml application/xhtml+xml application/rss+xml
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
</IfModule>

# ------------------------------------------------------
# Aggressive Caching Strategy
# ------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"

  # HTML - Short cache with must-revalidate
  # (Good for dynamic content, but Astro generates static HTML)
  ExpiresByType text/html "access plus 0 seconds"

  # CSS and JavaScript - 1 YEAR (Astro uses content hashing)
  # File names change when content changes, so aggressive caching is safe
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/x-javascript "access plus 1 year"

  # Web fonts - 1 YEAR (rarely change)
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/x-font-woff "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"
  ExpiresByType application/x-font-opentype "access plus 1 year"

  # Images - 1 YEAR (with content hashing)
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"

  # Favicon - 1 week (can update more frequently)
  ExpiresByType image/vnd.microsoft.icon "access plus 1 week"

  # Media files - 1 YEAR
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType video/webm "access plus 1 year"
  ExpiresByType audio/mp3 "access plus 1 year"
  ExpiresByType audio/mpeg "access plus 1 year"
  ExpiresByType audio/ogg "access plus 1 year"

  # Data & Feeds - Shorter cache
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  ExpiresByType text/xml "access plus 0 seconds"
  ExpiresByType application/rss+xml "access plus 1 hour"

  # Manifest files
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType text/cache-manifest "access plus 0 seconds"
</IfModule>

# ------------------------------------------------------
# Web Manifest Headers (Portfolio Edition)
# ------------------------------------------------------
<IfModule mod_headers.c>
  # Serve manifest with correct MIME type
  <FilesMatch "\.(webmanifest|manifest)$">
    Header set Content-Type "application/manifest+json; charset=utf-8"
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
  
  # Apple touch icon (for iOS)
  <FilesMatch "apple-touch-icon\.png$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# ------------------------------------------------------
# Cache-Control Headers (Fine-grained control)
# ------------------------------------------------------
<IfModule mod_headers.c>
  # HTML - No cache, must revalidate
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # CSS & JavaScript - 1 year, immutable
  # "immutable" tells browsers this file will NEVER change at this URL
  <FilesMatch "\.(css|js|mjs)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  # Images - 1 year, immutable
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|avif|ico)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  # Fonts - 1 year, immutable
  <FilesMatch "\.(ttf|otf|woff|woff2|eot)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  # Media - 1 year, public
  <FilesMatch "\.(mp4|webm|mp3|ogg)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>

  # Properly handle Vary header for compression
  <FilesMatch "\.(js|css|xml|gz|html|woff|woff2|ttf)$">
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>

# ------------------------------------------------------
# Security Headers (Bonus: Helps with some speed tests)
# ------------------------------------------------------
<IfModule mod_headers.c>
  # Prevent MIME type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Prevent clickjacking
  Header set X-Frame-Options "SAMEORIGIN"

  # Enable XSS protection
  Header set X-XSS-Protection "1; mode=block"

  # Referrer policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions policy (optional - customize as needed)
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ------------------------------------------------------
# ETags (Keep enabled for cache validation)
# ------------------------------------------------------
<IfModule mod_headers.c>
  # Keep ETags enabled - they help with cache validation
  FileETag MTime Size
</IfModule>

# ------------------------------------------------------
# Custom Error Pages
# ------------------------------------------------------
ErrorDocument 404 /404.html

# ------------------------------------------------------
# Performance: Disable ETags for static assets with long cache
# (Optional - ETags can actually help, but some prefer to disable)
# ------------------------------------------------------
# <IfModule mod_headers.c>
#   <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|js|css|swf|woff|woff2|ttf)$">
#     Header unset ETag
#   </FilesMatch>
# </IfModule>
# FileETag None

# ------------------------------------------------------
# Optional: Prevent access to sensitive files
# ------------------------------------------------------
<FilesMatch "(^\.htaccess|^\.env|\.md$)">
  Order allow,deny
  Deny from all
</FilesMatch>
